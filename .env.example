# ─────────────────────────────────────────────────────
# .env – Umgebungsvariablen für Stalwart SMTP Relay
# Kopieren: cp .env.example .env  → dann anpassen!
# ─────────────────────────────────────────────────────

# Hostname des Mail-Servers (FQDN – wichtig für SMTP Handshake!)
MAIL_HOSTNAME=mail.example.com

# Zeitzone
TIMEZONE=Europe/Berlin

# Admin-Passwort für das Web-Interface (Port 8080)
ADMIN_SECRET=changeme_sehr_sicheres_passwort

# Optional: Smarthost (Relay-Ziel, z.B. AWS SES, Sendgrid, etc.)
# Format: smtp://user:password@host:port
# Leer lassen = direkte MX-Zustellung
SMTP_SMARTHOST=

# Optional: Absender-Domain für DKIM Signierung
MAIL_DOMAIN=example.com
