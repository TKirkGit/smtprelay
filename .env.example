# ─────────────────────────────────────────────────────
# .env – Umgebungsvariablen für Stalwart SMTP Relay
# Kopieren: cp .env.example .env  → dann anpassen!
# ─────────────────────────────────────────────────────

# Zeitzone
TIMEZONE=Europe/Berlin

# ─────────────────────────────────────────────────────
# HINWEIS: Stalwart generiert beim ersten Start automatisch:
#   - Die Konfiguration unter /opt/stalwart/etc/config.toml
#   - Ein Admin-Passwort (sichtbar in: docker logs stalwart)
#
# Alle weiteren Einstellungen (Hostname, Domain, TLS, DKIM,
# Relay-Ziele etc.) werden über das Web-Interface konfiguriert:
#   http://<SERVER-IP>:8080
# ─────────────────────────────────────────────────────
